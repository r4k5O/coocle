# Coocle Environment Configuration

# Database Path (default: data/coocle.db)
# COOCLE_DB=data/coocle.db

# --- CRAWLER SETTINGS ---
# Start crawler automatically with the API server
# COOCLE_START_CRAWLER=0

# Comma-separated seed URLs for the crawler
# COOCLE_SEEDS=https://example.com,https://docs.python.org

# Delay between requests in seconds
# COOCLE_DELAY_S=0.6

# Optional crawler limits
# COOCLE_MAX_PAGES=0
# COOCLE_MAX_DEPTH=10
# COOCLE_SAME_HOST_ONLY=0

# --- OLLAMA / SUMMARIZATION ---
# Host for the local Ollama instance
OLLAMA_HOST=http://localhost:11434

# Model to use for summarization
OLLAMA_CHAT_MODEL=deepseek-r1:1.5b

# Optional local API key for self-hosted gateways / compatible providers
# OLLAMA_API_KEY=

# Optional: Cloud configuration if not using local
# OLLAMA_CLOUD_HOST=https://ollama.com/api
# OLLAMA_CLOUD_API_KEY=your_key_here
# OLLAMA_CLOUD_MODEL=deepseek-r1:1.5b

# Trust X-Forwarded-For / X-Real-IP headers when running behind a reverse proxy
# COOCLE_TRUST_PROXY_HEADERS=0

# --- ASTRADB (Cloud Vector Store) ---
USE_ASTRA=false
# COOCLE_PREWARM_ASTRA=0
ASTRA_DB_APPLICATION_TOKEN=
ASTRA_DB_API_ENDPOINT=
ASTRA_DB_COLLECTION=coocle_pages
